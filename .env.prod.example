# ============================================================
# Production Docker Compose environment
# Copy to .env and fill in all values:
#   cp .env.prod.example .env
# ============================================================

# ---- Domain ------------------------------------------------
# No protocol, no trailing slash
DOMAIN=astrokomunita.sk

# ---- App ---------------------------------------------------
APP_NAME=Astrokomunita
# Generate: docker compose -f docker-compose.prod.yml run --rm backend php artisan key:generate --show
APP_KEY=base64:CHANGE_THIS

# ---- Database ----------------------------------------------
# Must match DB_PASSWORD / DB_ROOT_PASSWORD in backend/.env
DB_DATABASE=astrokomunita
DB_USERNAME=astro
DB_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD
DB_ROOT_PASSWORD=CHANGE_THIS_STRONG_ROOT_PASSWORD

# ---- Redis -------------------------------------------------
# Must match REDIS_PASSWORD in backend/.env
REDIS_PASSWORD=CHANGE_THIS_STRONG_REDIS_PASSWORD

# ---- Reverb WebSocket --------------------------------------
# Must match REVERB_APP_* in backend/.env
REVERB_APP_ID=CHANGE_THIS
REVERB_APP_KEY=CHANGE_THIS
REVERB_APP_SECRET=CHANGE_THIS

# ---- Internal service tokens -------------------------------
# Generate random strings: openssl rand -hex 32
# Must match INTERNAL_TOKEN / *_INTERNAL_TOKEN in backend/.env
INTERNAL_TOKEN=CHANGE_THIS
MODERATION_INTERNAL_TOKEN=CHANGE_THIS
LIBRETRANSLATE_INTERNAL_TOKEN=CHANGE_THIS

# ---- Frontend build vars -----------------------------------
# Baked into the Vue JS bundle at image build time
LEGAL_CONTROLLER_NAME=Astrokomunita
LEGAL_CONTACT_EMAIL=info@astrokomunita.sk
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=production
VITE_SENTRY_RELEASE=

# ---- Backend telemetry -------------------------------------
# Optional Sentry DSN for backend exception reporting
SENTRY_DSN=

# ---- Backup policy -----------------------------------------
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14

# ---- Runtime image pins ------------------------------------
# Keep these pinned for deterministic deploys.
CADDY_IMAGE=caddy:2.8-alpine
NGINX_IMAGE=nginx:1.27-alpine
MYSQL_IMAGE=mysql:8.4
REDIS_IMAGE=redis:7.2-alpine
LIBRETRANSLATE_IMAGE=libretranslate/libretranslate:latest
OLLAMA_IMAGE=ollama/ollama:latest

# ---- Application images (overridden by CI deploy job) ------
BACKEND_IMAGE=astrokomunita-backend:prod
FRONTEND_IMAGE=astrokomunita-frontend:prod
SKY_IMAGE=astrokomunita-sky:prod
MODERATION_IMAGE=astrokomunita-moderation:prod
