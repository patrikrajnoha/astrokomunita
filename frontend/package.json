{
  "name": "astrokomunita-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "node --max-http-header-size=65536 ./node_modules/vite/bin/vite.js",
    "build": "vite build",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:node": "node --test tests-node/**/*.test.*",
    "test:ui": "vitest run",
    "preview": "vite preview",
    "lint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "html-to-image": "^1.11.13",
    "laravel-echo": "^2.3.0",
    "pinia": "^3.0.4",
    "plyr": "^3.8.4",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "~10.6.2",
    "globals": "^16.5.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.6",
    "prettier": "3.7.4",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.0",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitest": "^2.1.8"
  }
}
