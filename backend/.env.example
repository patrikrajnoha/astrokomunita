APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8001
HEALTH_EXPOSE_DIAGNOSTICS=false
SECURITY_HEADERS_ENABLED=true
SECURITY_HEADER_X_FRAME_OPTIONS=SAMEORIGIN
SECURITY_HEADER_X_CONTENT_TYPE_OPTIONS=nosniff
SECURITY_HEADER_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_HEADER_PERMISSIONS_POLICY="camera=(), geolocation=(), microphone=()"
SECURITY_HEADER_X_PERMITTED_CROSS_DOMAIN_POLICIES=none
SECURITY_HEADER_HSTS_MAX_AGE=31536000
SECURITY_HEADER_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HEADER_HSTS_PRELOAD=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
