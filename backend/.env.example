# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENV=local
SENTRY_RELEASE=
SENTRY_TIMEOUT_SECONDS=2.5

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=astrokomunita
