# ============================================================
# Laravel production environment
# Copy to backend/.env and fill in all CHANGE_THIS values.
# ============================================================

# ---- App ---------------------------------------------------
APP_NAME=Astrokomunita
APP_ENV=production
# (*) Generate: php artisan key:generate --show
APP_KEY=base64:CHANGE_THIS
APP_DEBUG=false
APP_URL=https://api.YOUR_DOMAIN
HEALTH_EXPOSE_DIAGNOSTICS=false

# ---- Security headers --------------------------------------
SECURITY_HEADERS_ENABLED=true
SECURITY_HEADER_X_FRAME_OPTIONS=SAMEORIGIN
SECURITY_HEADER_X_CONTENT_TYPE_OPTIONS=nosniff
SECURITY_HEADER_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_HEADER_PERMISSIONS_POLICY="camera=(), geolocation=(), microphone=()"
SECURITY_HEADER_X_PERMITTED_CROSS_DOMAIN_POLICIES=none
SECURITY_HEADER_HSTS_MAX_AGE=31536000
SECURITY_HEADER_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HEADER_HSTS_PRELOAD=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

# ---- Logging -----------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_RETENTION_DAYS=30

# ---- Sentry ------------------------------------------------
SENTRY_ENABLED=true
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_RELEASE=
SENTRY_TIMEOUT_SECONDS=2.5

# ---- Database ----------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=astrokomunita
# (*) Must match DB_USERNAME / DB_PASSWORD in root .env
DB_USERNAME=astro
DB_PASSWORD=CHANGE_THIS

# ---- Redis / Queue -----------------------------------------
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
# (*) Must match REDIS_PASSWORD in root .env
REDIS_PASSWORD=CHANGE_THIS

# ---- Session -----------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=10080
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.YOUR_DOMAIN
SESSION_SAME_SITE=none
SESSION_SECURE_COOKIE=true

# ---- Broadcasting (Reverb) ---------------------------------
BROADCAST_CONNECTION=reverb
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_SERVER_PATH=
# Internal Docker hostname, Caddy handles public TLS termination
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
# (*) Must match REVERB_APP_* in root .env
REVERB_APP_ID=CHANGE_THIS
REVERB_APP_KEY=CHANGE_THIS
REVERB_APP_SECRET=CHANGE_THIS

# ---- File storage ------------------------------------------
FILESYSTEM_DISK=local
FILES_DISK=public
FILES_PRIVATE_DISK=local
POST_ATTACHMENT_MAX_KB=32768
OBSERVATION_IMAGE_MAX_KB=32768
POLL_OPTION_IMAGE_MAX_KB=20480
PROFILE_UPLOAD_MAX_KB=20480

# Optional Cloudflare R2 setup
# FILES_DISK=r2_public
# FILES_PRIVATE_DISK=r2_private
# FILES_CLOUD_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=auto
# AWS_BUCKET=your-public-bucket
# AWS_URL=https://pub-XXXX.r2.dev
# AWS_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
# AWS_USE_PATH_STYLE_ENDPOINT=true
# R2_PRIVATE_BUCKET=your-private-bucket

# ---- Email -------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=CHANGE_THIS
MAIL_PASSWORD=CHANGE_THIS
MAIL_FROM_ADDRESS=noreply@YOUR_DOMAIN
MAIL_FROM_NAME="${APP_NAME}"
MAIL_VERIFICATION_FROM_ADDRESS=noreply@YOUR_DOMAIN
MAIL_SCHEME=null

# ---- Auth / CORS -------------------------------------------
SANCTUM_STATEFUL_DOMAINS=YOUR_DOMAIN,api.YOUR_DOMAIN
CORS_ALLOWED_ORIGINS=https://YOUR_DOMAIN,https://api.YOUR_DOMAIN
AUTH_ENABLE_SIGNED_LINK_EMAIL_VERIFICATION=false
AUTH_LEGACY_PLAINTEXT_ENABLED=false
AUTH_LEGACY_PLAINTEXT_ALLOW_NON_LOCAL=false

# ---- Newsletter --------------------------------------------
NEWSLETTER_FRONTEND_BASE_URL=https://YOUR_DOMAIN
NEWSLETTER_QUEUE=default
NEWSLETTER_CHUNK_SIZE=100
NEWSLETTER_BATCH_SIZE=200
NEWSLETTER_RATE_LIMIT_PER_MINUTE=600
NEWSLETTER_MAX_RECIPIENTS_PER_RUN=0
NEWSLETTER_TOP_ARTICLES_LIMIT=4
NEWSLETTER_UNSUBSCRIBE_URL_TTL_DAYS=30
VITE_LOG_RETENTION_DAYS="${LOG_RETENTION_DAYS}"
VITE_NOTIFICATION_RETENTION_DAYS=90

# ---- Legal -------------------------------------------------
LEGAL_CONTROLLER_NAME=Astrokomunita
LEGAL_CONTACT_EMAIL=CHANGE_THIS@YOUR_DOMAIN
VITE_LEGAL_CONTROLLER_NAME="${LEGAL_CONTROLLER_NAME}"
VITE_LEGAL_CONTACT_EMAIL="${LEGAL_CONTACT_EMAIL}"

# ---- Internal service tokens -------------------------------
# (*) Generate: openssl rand -hex 32
INTERNAL_TOKEN=CHANGE_THIS
TRANSLATION_INTERNAL_TOKEN=CHANGE_THIS
LIBRETRANSLATE_INTERNAL_TOKEN=CHANGE_THIS
MODERATION_INTERNAL_TOKEN=CHANGE_THIS

# ---- Translation -------------------------------------------
TRANSLATION_PROVIDER=libretranslate
TRANSLATION_FALLBACK_PROVIDER=none
TRANSLATION_TIMEOUT_SECONDS=12
TRANSLATION_CONNECT_TIMEOUT_SECONDS=3
TRANSLATION_RETRIES=2
TRANSLATION_CACHE_ENABLED=true
TRANSLATION_CACHE_TTL=86400
TRANSLATION_EVENTS_ENABLED=true
LIBRETRANSLATE_BASE_URL=http://libretranslate:5000
LIBRETRANSLATE_TIMEOUT=12
LIBRETRANSLATE_VERIFY_SSL=true

# ---- Moderation --------------------------------------------
MODERATION_ENABLED=true
MODERATION_ENFORCE_UPLOAD_IMAGE_SCAN=true
MODERATION_BASE_URL=http://moderation:8090
MODERATION_TIMEOUT_SECONDS=8
MODERATION_FALLBACK_POLICY=pending_blur_retry
MODERATION_IMAGE_MAX_BYTES=33554432
MODERATION_IMAGE_RESIZE_MAX_WIDTH=1600
MODERATION_IMAGE_RESIZE_JPEG_QUALITY=78
MODERATION_IMAGE_RESIZE_GD_MAX_PIXELS=16000000

# ---- Sky microservice --------------------------------------
OBSERVING_SKY_MICROSERVICE_BASE=http://sky:8010
TRANSLATION_SERVICE_URL=http://sky:8010

# ---- AI / Ollama (disabled by default) ---------------------
# Enable only if running with --profile ai
OLLAMA_BASE_URL=http://ollama:11434
AI_OLLAMA_REFINEMENT_ENABLED=false
BOT_TRANSLATION_POST_EDIT_ENABLED=false
EVENTS_REFINE_DESCRIPTIONS_WITH_OLLAMA=false
EVENTS_AI_DESCRIPTION_MODE=template

# ---- Cloudflare Turnstile ----------------------------------
# (*) Get keys from Cloudflare Dashboard > Turnstile
TURNSTILE_ENABLED=true
TURNSTILE_SECRET_KEY=CHANGE_THIS

# ---- Seeding (disabled by default in production) -----------
# Set to true and run: php artisan app:seed-default-users --force
SEED_DEFAULT_USERS_ENABLED=false
SEED_ADMIN_EMAIL=CHANGE_THIS@YOUR_DOMAIN
SEED_ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ---- External APIs -----------------------------------------
NASA_API_KEY=DEMO_KEY
OPENAQ_API_KEY=
TENOR_API_KEY=
GIPHY_API_KEY=

# ---- Events ------------------------------------------------
EVENTS_DISPLAY_TIMEZONE=Europe/Bratislava
EVENTS_NASA_LOCATION_LABEL="Bratislava, SK"
EVENTS_NASA_LOCATION_LAT=48.1486
EVENTS_NASA_LOCATION_LON=17.1077
EVENTS_NASA_LOCATION_HEIGHT_M=150
EVENTS_DESCRIPTION_TEMPLATE_MIN_LENGTH=40

# ---- SSL verification --------------------------------------
HTTP_CLIENT_ALLOW_INSECURE_SSL=false
ASTROBOT_SSL_VERIFY=true
EVENTS_CRAWLER_SSL_VERIFY=true
LIBRETRANSLATE_VERIFY_SSL=true
